{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:tsumugi",
  "type": "Actor",
  "name": "tsumugi",
  "glyph": "紡ぎ",
  "purpose": "Engi Knowledge Graph (産霊の網) intel weaver — Spirit-in-Physics over real public power-entities; surfaces 取-concentration routed to release.",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606011800",
  "extendedByAdr": ["2606061500", "2606092000"],
  "dependsOnAdr": ["2606011000", "2606011500", "2605081300", "2605170000", "2605301600", "2605301400", "2605302300", "2605241500", "2606042330"],
  "schema": ["00-contracts/schemas/engi-organism-ontology.kotoba.edn", "00-contracts/schemas/spirit-ontology.kotoba.edn", "00-contracts/schemas/influence-history-ontology.kotoba.edn", "00-contracts/schemas/power-scale-ontology.kotoba.edn", "00-contracts/schemas/banner-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345)",
    "largeAssets": "DataLad → IPFS (80-data/spirit-in-physics) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)"
  },
  "integrates": ["actor:danjo", "actor:kanae", "actor:tadori", "actor:himotoki"],
  "cells": [
    {
      "id": "cell:tsumugi.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-power-graph.kotoba.edn",
      "output": ["out/intel-report.md", "out/spirit-graph.kotoba.edn"],
      "pipeline": "rbf-kernel → laplacian → spectral-embed-3 → tensegrity-unilateral → 取-concentration"
    },
    {
      "id": "cell:tsumugi.analyze-influence",
      "adr": "2606061500",
      "method": "methods/analyze_influence.py",
      "input": "data/seed-influence-history.kotoba.edn",
      "output": ["out/influence-report.md", "out/influence-graph.kotoba.edn"],
      "pipeline": "temporal-dag(N5) → rbf-kernel → spectral-embed-3 → tensegrity-unilateral → katz-reach(outbound/inbound/broker)",
      "doc": "diachronic influence-as-information-flow over PUBLIC historical figures/documents/events/traditions (incl. YHWH/Jesus/Buddha as influence nodes); mirror-only, non-eschatological, edge-primary"
    },
    {
      "id": "cell:tsumugi.project-influence-posts",
      "adr": "2606061500",
      "method": "methods/project_influence_posts.py",
      "input": "data/seed-influence-history.kotoba.edn",
      "output": ["out/influence-posts.dryrun.kotoba.edn"],
      "pipeline": "mirror-observer-voice (N2, impersonation-refused) → published=false (G7 dry-run)",
      "lexicon": ["com.etzhayyim.influence.influencePost", "com.etzhayyim.influence.influenceFlow"]
    },
    {
      "id": "cell:tsumugi.coverage-influence",
      "adr": "2606061500",
      "method": "methods/coverage_report.py",
      "input": "data/seed-influence-history.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "era-spine + civilizational-stream + denominator + connectedness → gap-map",
      "doc": "honest coverage measurement (all-humanity ~0 by design); names thin/missing eras + streams per wave"
    },
    {
      "id": "cell:tsumugi.ingest-influence",
      "adr": "2606061500",
      "method": "methods/ingest_influence.py",
      "input": "data/ingest-influence/*.json",
      "output": ["out/influence-ingested.kotoba.edn", "out/seed-plus-ingest.kotoba.edn"],
      "pipeline": "wikidata-P737/pantheon → N4(deceased-only)/N5(forward)/N2(mirror)/G5 → :flow/ 縁 merge",
      "gate": "G7 — offline fixtures by default; --live refused unless TSUMUGI_OPERATOR_GATE=1 + operator DID + Council"
    },
    {
      "id": "cell:tsumugi.analyze-scale",
      "adr": "2606092000",
      "method": "methods/analyze_scale.py",
      "input": "data/seed-scale-power.kotoba.edn",
      "output": ["out/scale-report.md", "out/scale-graph.kotoba.edn"],
      "pipeline": "validate(S1/S2/S4/S5) → per-locality cross-sector integral × diversity → per-scale aggregate → cross-sector brokers",
      "doc": "(A) scale-agnostic 産官学報 concentration over local/regional/intra-org/national scales (長崎 flagship); edge-primary, person-excluded (seats only), non-adjudicating, map-not-target"
    },
    {
      "id": "cell:tsumugi.analyze-banner",
      "adr": "2606092000",
      "method": "methods/analyze_banner.py",
      "input": "data/seed-banner.kotoba.edn",
      "output": ["out/banner-report.md", "out/banner-graph.kotoba.edn"],
      "pipeline": "validate(H1/H2/H3/H4/H7) → per-banner reach integral → camps → bridges(H6) → genealogy(← thought-stream)",
      "doc": "(B / 旗 hata) declared ideology/faction camps; basis always on-the-record (H1), non-adjudicating no-threat-token (H2), edge-primary no-conviction-score (H3), person-excluded (H4), plural (H6)"
    },
    {
      "id": "cell:tsumugi.narrate",
      "adr": "2606092000",
      "method": "methods/narrate.py",
      "deploy": "deploy/agent.py",
      "input": ["data/seed-scale-power.kotoba.edn", "data/seed-banner.kotoba.edn"],
      "output": ["out/intel-digest.kotoba.edn", "out/narration.dryrun.md", "out/narration.md"],
      "pipeline": "analyze(scale+banner+vertical) → build-digest(fused kotoba-EDN, Datom/Murakumo-consumable) → build-prompt(aggregate-only) → infer(Murakumo LiteLLM 127.0.0.1:4000 / gemma3:4b·Maxwell, G6) → emit(published=false, G7)",
      "doc": "Murakumo-only intel narration: stdlib twin methods/narrate.py (urllib, operator-gated, refuses non-fleet host) + canonical in-WASM deploy/agent.py (kotoba_langgraph → KotobaLLM → host MURAKUMO_DEFAULT_MODEL gemma4; himawari pattern). Mirror + non-adjudicating; no published post.",
      "gate": "G6 Murakumo-only (ADR-2605215000) + G7 dry-run by default (TSUMUGI_MURAKUMO_GATE=1 + fleet reachable for a live call)"
    }
  ],
  "gates": {
    "G1": "power-only scope; powerless absent by construction (§D8/§D9)",
    "G2": "edge-primary karma (N1) — no per-soul score",
    "G3": "aggregate-first + claimed-first",
    "G4": "public venue (open + on-chain + 1 SBT = 1 vote)",
    "G5": "sourcing honesty (:authoritative | :representative)",
    "G6": "Murakumo-only narration",
    "G7": "outward-gated (live ingest = Council + operator)",
    "G8": "no git-lfs; DataLad → IPFS",
    "G9": "要配慮 PII → XChaCha20-Poly1305 envelope"
  },
  "historicalExtension": {
    "adr": "2606061500",
    "scope": ":historical scale — diachronic influence over PUBLIC historical figures/documents/events/traditions (incl. YHWH/Jesus/Buddha as influence nodes); scaffolds now (public, no PII, like :institutional/:self scales of spirit-ontology)",
    "invariants": {
      "N1": "edge-primary — influence on :flow/signed-weight only; node readouts are integrals (no :influence/score-of-figure)",
      "N2": "mirror, never impersonation — :mirror/is-mirror const true; :post/voice const :observer; first-person unrepresentable",
      "N3": "non-eschatological + non-adjudicating truth — datafy INFLUENCE OF a tradition, never its theological truth; no verdict/salvation/afterlife datom (Charter §1.15)",
      "N4": "public + long-settled + no PII — public influence-bearing figures only; living-private persons stay the Council-Lv7+-gated :human scale",
      "N5": "temporal DAG — every :flow points forward in time (source.year-from ≤ receiver.year-to)"
    }
  },
  "scaleBannerExtension": {
    "adr": "2606092000",
    "scope": "(A) scale-agnostic 産官学報 concentration (local/regional/intra-org/学会/会社/national — same lens every scale; 長崎 flagship) + (B / 旗 hata) declared ideology/faction camps projecting historical thought-streams to the present. + granularity axis :pwr/collective-kind {組織/地域/コミュニティ/社内派閥/学閥/系列/審議会} (still seat/institution-level, never a roster of persons). + Murakumo-only LangGraph narration (cell:tsumugi.narrate / deploy/agent.py).",
    "scaleInvariants": {
      "S1": "edge-primary — concentration on :tie/grasping-load only; no :pwr/power-score (raises)",
      "S2": "person-excluded — :pwr/standing ∈ {:institutional :public-seat}; :private-person unrepresentable",
      "S3": "aggregate-first — per-locality/per-scale; brokers are seat/org ids",
      "S4": "sourcing honesty — every :tie ≥2 public citations; under-sourced raises",
      "S5": "non-adjudicating — verdict tokens (癒着/談合/capture) unrepresentable (raises)",
      "S6": "map-not-target — openness/resilience map routed to opening"
    },
    "bannerInvariants": {
      "H1": "public-declared basis only — :flies/basis on-the-record; :inferred/:suspected/:imputed raise",
      "H2": "non-adjudicating — threat tokens (:extremist/:過激/:危険思想) unrepresentable; no threat-level/loyalty",
      "H3": "edge-primary — alignment on :flies/* only; no :ent/ideology-score (raises)",
      "H4": "person-excluded — :flies/who institutional/public-seat/self only; not a belief registry",
      "H5": "mirror + symmetric — etzhayyim flies its own Charter banner inbound-only",
      "H6": "plural — many-to-many; ≥2-banner entities are bridges, not anomalies",
      "H7": "sourcing — every :flies ≥2 public citations (own manifesto/statement/vote)"
    }
  }
}
